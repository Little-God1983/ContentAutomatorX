@using ContentAutomatorX.Application.Newsletter
@using ContentAutomatorX.Application.Services
@using ContentAutomatorX.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@inject NewsletterTemplateService Templates
@inject ISnackbar Snackbar

<style>
    /* MudTextField sizes its textarea from Lines (a rows attribute); these two rules hand that
       control back to flexbox so the editor fills whatever height the dialog gives it. */
    .template-html-editor {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    /* Every wrapper between the field root and the textarea must pass the height down; missing
       any one of them collapses the box back to its Lines row-count. */
    .template-html-editor .mud-input-control,
    .template-html-editor .mud-input-control-input-container,
    .template-html-editor .mud-input {
        display: flex;
        flex: 1 1 auto;
        min-height: 0;
    }
    .template-html-editor textarea {
        height: 100% !important;
        flex: 1 1 auto;
        resize: none;
    }

    /* flex:0 0 auto so expanding the reference shrinks the editor rather than overflowing the pane. */
    .template-reference {
        flex: 0 0 auto;
        max-height: 32vh;
        overflow: auto;
        font-size: 11px;
        line-height: 1.7;
    }
    .template-reference .ref-block { font-family: monospace; font-weight: 600; }
    .template-reference .ref-state { margin-left: 8px; font-size: 10px; text-transform: uppercase; }
    .template-reference .ref-token {
        display: inline-block;
        margin: 1px 4px 1px 0;
        padding: 0 4px;
        border-radius: 3px;
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-lines-default);
        font-family: monospace;
    }
    .template-reference .ref-cond { opacity: .75; }
</style>

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="gap:8px">
            <MudTextField @bind-Value="_name" Label="Template name" Margin="Margin.Dense" Class="flex-grow-1" />
            <MudSwitch @bind-Value="_isDefault" Color="Color.Primary" Label="Tenant default" />
        </div>
    </TitleContent>
    @* DialogContent is a RenderFragment, not a component — it takes no attributes, so the sizing
       lives on this wrapper. Fill the full-screen dialog: the split stretches to the available
       height instead of a fixed 65vh that left the lower half of the screen blank. *@
    <DialogContent>
      <div class="d-flex flex-column" style="height:calc(100vh - 190px);overflow:hidden">
        <div class="d-flex flex-grow-1" style="gap:12px; min-height:0">
            <div class="d-flex flex-column" style="flex:1 1 50%; min-width:0">
                <div class="d-flex align-center mb-2" style="gap:8px">
                    <MudFileUpload T="IBrowserFile" Accept=".html,.htm" FilesChanged="UploadAsync">
                        <CustomContent>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@context.OpenFilePickerAsync"
                                       StartIcon="@Icons.Material.Filled.UploadFile">Upload .html</MudButton>
                        </CustomContent>
                    </MudFileUpload>
                    <MudText Typo="Typo.caption">@(_html.Length / 1024) KB</MudText>
                    <MudSpacer />
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _showReference = !_showReference)"
                               StartIcon="@(_showReference ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)">
                        Blocks &amp; placeholders
                    </MudButton>
                </div>
                @* Lines is still required — it is what makes MudTextField render a <textarea> at all —
                   but the CSS below overrides the row-count height so the box grows with the pane. *@
                <MudTextField @bind-Value="_html" @bind-Value:after="OnHtmlChanged" Lines="24"
                              Variant="Variant.Outlined" Class="template-html-editor flex-grow-1"
                              Style="font-family:monospace;font-size:12px"
                              Immediate="true" DebounceInterval="400" />
                @if (_showReference)
                {
                    @* Generated from TemplatePlaceholders/TemplateBlocks — the same data the validator
                       rejects against — so this panel can never drift from what is actually allowed. *@
                    <div class="template-reference mt-2">
                        @foreach (var name in ReferenceBlockOrder)
                        {
                            var present = _blocks.Contains(name);
                            var conditions = TemplatePlaceholders.Conditions(name).Order().ToList();
                            <div class="mb-2">
                                <span class="ref-block">&lt;!-- BLOCK: @name --&gt;</span>
                                <span class="ref-state" style="color:@(present
                                    ? "var(--mud-palette-success)" : "var(--mud-palette-text-disabled)")">
                                    @(present ? "defined"
                                        : name == TemplateBlocks.Shell ? "required — missing" : "missing → built-in design")
                                </span>
                                <div>
                                    @foreach (var p in TemplatePlaceholders.For(name).Order())
                                    {
                                        <code class="ref-token">{{@p}}</code>
                                    }
                                    @if (conditions.Count > 0)
                                    {
                                        @foreach (var c in conditions)
                                        {
                                            <code class="ref-token ref-cond">&lt;!-- IF: @c --&gt;</code>
                                        }
                                    }
                                </div>
                            </div>
                        }
                        <MudText Typo="Typo.caption" Class="d-block mt-1">
                            IF regions cannot nest. Text outside any BLOCK is ignored.
                        </MudText>
                    </div>
                }
            </div>
            <div class="d-flex flex-column" style="flex:1 1 50%; min-width:0">
                <MudText Typo="Typo.caption" Class="mb-2">Preview — sample issue</MudText>
                <iframe sandbox srcdoc="@_preview" title="Template preview"
                        style="flex:1;width:100%;border:1px solid var(--mud-palette-lines-default);background:#fff"></iframe>
            </div>
        </div>
        @if (_issues.Count > 0)
        {
            <div class="mt-2" style="max-height:18vh;overflow:auto;flex:0 0 auto">
                @foreach (var issue in _issues)
                {
                    <MudText Typo="Typo.caption" Class="d-block"
                             Color="@(issue.Level == TemplateIssueLevel.Error ? Color.Error : Color.Warning)">
                        @(issue.Level == TemplateIssueLevel.Error ? "✗" : "⚠") line @issue.Line — @issue.Message
                    </MudText>
                }
            </div>
        }
      </div>
    </DialogContent>
    <DialogActions>
        @if (!IsNew)
        {
            <MudButton Color="Color.Error" Disabled="@_busy" OnClick="DeleteAsync">Delete</MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="@(() => Dialog.Cancel())">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_busy || _hasErrors)" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter, EditorRequired] public NewsletterTemplate Template { get; set; } = default!;

    /// <summary>True when this dialog was opened for a template that has never been saved
    /// (Recipes.razor's NewTemplateAsync). The template's Id is never a reliable signal for this —
    /// every entity in this codebase defaults Id to a fresh Guid.NewGuid() on construction, so an
    /// unsaved template already carries a non-empty id and Id != Guid.Empty is always true. Delete
    /// must be hidden here rather than inferred, since deleting a never-saved template is a silent
    /// no-op (NewsletterTemplateService.DeleteAsync finds no row) that would otherwise still show a
    /// "Template deleted." success snackbar.</summary>
    [Parameter] public bool IsNew { get; set; }

    /// <summary>The authoritative tenant for Save/Delete — sourced from Recipes.razor's TenantContext,
    /// not from Template.TenantId, which NewsletterTemplateService now treats as untrusted (see its
    /// own comments): this dialog has no TenantContext of its own, so the caller must hand it in.</summary>
    [Parameter, EditorRequired] public Guid TenantId { get; set; }

    private NewsletterTemplate _template = default!;
    private string _name = "", _html = "", _preview = "";
    private bool _isDefault, _busy, _hasErrors, _showReference;
    private IReadOnlyList<TemplateIssue> _issues = [];

    /// <summary>Block names the current text actually defines — drives the defined/missing marker.</summary>
    private IReadOnlySet<string> _blocks = new HashSet<string>();

    /// <summary>Shell first because it is the one required block and the document everything else
    /// sits inside; the rest in TemplateBlocks.Optional's order, which is the order they appear in
    /// a rendered issue. TemplateBlocks.All is a HashSet and has no order worth showing.</summary>
    private static readonly IReadOnlyList<string> ReferenceBlockOrder =
        [TemplateBlocks.Shell, .. TemplateBlocks.Optional];

    protected override void OnInitialized()
    {
        _template = Template;
        _name = _template.Name;
        _html = _template.Html;
        _isDefault = _template.IsDefault;
        OnHtmlChanged();
    }

    /// <summary>Never throws: a broken template must leave the editor usable, and there is no
    /// ErrorBoundary in this app — an exception here would tear down the circuit.</summary>
    private void OnHtmlChanged()
    {
        try
        {
            _issues = TemplateValidator.Validate(_html);
            _hasErrors = TemplateValidator.HasErrors(_issues);
            _blocks = TemplateParser.Parse(_html).Blocks.Keys.ToHashSet();
            var rendered = TemplateHtmlRenderer.Render(SampleIssue.Sections, SampleIssue.Tenant,
                "Signals from the latent space", _html, DateTimeOffset.UtcNow);
            // Keep the last good preview when the new one is empty (no shell yet, mid-typing).
            if (!string.IsNullOrWhiteSpace(rendered))
                _preview = rendered.Replace(SectionHtmlRenderer.UnsubscribeToken, "#");
        }
        catch (Exception ex)
        {
            _issues = [new TemplateIssue(TemplateIssueLevel.Error, 1, $"Preview failed: {ex.Message}")];
            _hasErrors = true;
        }
    }

    private async Task UploadAsync(IBrowserFile? file)
    {
        if (file is null) return;
        try
        {
            if (file.Size > TemplateValidator.MaxBytes)
            {
                Snackbar.Add($"That file is larger than {TemplateValidator.MaxBytes / 1024} KB.", Severity.Error);
                return;
            }
            using var stream = file.OpenReadStream(TemplateValidator.MaxBytes);
            using var reader = new StreamReader(stream);
            _html = await reader.ReadToEndAsync();
            if (string.IsNullOrWhiteSpace(_name)) _name = Path.GetFileNameWithoutExtension(file.Name);
            OnHtmlChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read that file: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            _template.Name = _name;
            _template.Html = _html;
            _template.IsDefault = _isDefault;
            await Templates.SaveAsync(_template, TenantId);
            Snackbar.Add("Template saved.", Severity.Success);
            Dialog.Close(DialogResult.Ok(_template));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync()
    {
        _busy = true;
        try
        {
            await Templates.DeleteAsync(_template.Id, TenantId);
            Snackbar.Add("Template deleted.", Severity.Success);
            Dialog.Close(DialogResult.Ok((NewsletterTemplate?)null));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _busy = false; }
    }
}
