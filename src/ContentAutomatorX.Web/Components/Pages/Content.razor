@page "/content"
@page "/inbox"
@implements IDisposable
@inject TenantContext Ctx
@inject ContentService ContentSvc
@inject SourceService SourceSvc
@inject RecipeService RecipeSvc
@inject IServiceScopeFactory ScopeFactory
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Inbox</MudText>

@if (!Ctx.Initialized)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (Ctx.Active is null)
{
    <NoTenantHint />
}
else
{
    <div class="d-flex flex-wrap mb-4" style="gap:16px">
        <MudSelect T="string" Value="_statusFilter" ValueChanged="OnFilterChanged" Label="Status" Style="min-width:130px">
            <MudSelectItem T="string" Value="@("all")">All</MudSelectItem>
            @foreach (var s in Enum.GetNames<ContentItemStatus>())
            {
                <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" Value="_typeFilter" ValueChanged="OnTypeFilterChanged" Label="Source type" Style="min-width:160px">
            <MudSelectItem T="string" Value="@("all")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.Reddit">Reddit</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.Rss">RSS/Atom feed</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.Website">Website</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.LlmResearch">LLM research</MudSelectItem>
        </MudSelect>
        <MudDatePicker Label="From" Date="_from" DateChanged="@(d => { _from = d; ApplyFilters(); })"
                       Clearable="true" Style="min-width:150px" />
        <MudDatePicker Label="To" Date="_to" DateChanged="@(d => { _to = d; ApplyFilters(); })"
                       Clearable="true" Style="min-width:150px" />
        <MudSelect T="string" Value="_sortMode" ValueChanged="OnSortChanged" Label="Sort" Style="min-width:200px">
            <MudSelectItem T="string" Value="@("date")">Newest first</MudSelectItem>
            <MudSelectItem T="string" Value="@("rank")">As fetched (source order, e.g. hot)</MudSelectItem>
            <MudSelectItem T="string" Value="@("score")">Most upvotes</MudSelectItem>
        </MudSelect>
        <MudTextField T="string" Value="_search" ValueChanged="@((string v) => { _search = v; ApplyFilters(); })"
                      Immediate="true" DebounceInterval="300" Label="Search title & text" Clearable="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Style="min-width:240px" />
    </div>

    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle1">Generate from hand-picked items (@_selectedItems.Count selected)</MudText>
        <MudSelect T="Guid?" @bind-Value="_recipeId" Label="Recipe">
            @foreach (var r in _recipes)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)r.Id)">@r.Name (@r.Kind)</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_extraInstructions" Label="Extra instructions for this run (optional)" />
        <MudButton OnClick="RunWithSelection" Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                   Disabled="@(_recipeId is null || _selectedItems.Count == 0 || _running)">Generate draft</MudButton>
        <MudButton OnClick="DeleteSelected" Variant="Variant.Outlined" Color="Color.Error" Class="mt-2 ml-2"
                   Disabled="@(_selectedItems.Count == 0 || _running)">Delete selected</MudButton>
    </MudPaper>

    <MudTable T="ContentItem" Items="_items" Hover="true" MultiSelection="true" @bind-SelectedItems="_selectedItems">
        <HeaderContent>
            <MudTh>Title</MudTh><MudTh>Source</MudTh><MudTh>Upvotes</MudTh><MudTh>Published</MudTh><MudTh>Status</MudTh><MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @if (context.Url is not null)
                {
                    <MudLink Href="@context.Url" Target="_blank">@context.Title</MudLink>
                }
                else
                {
                    @context.Title
                }
            </MudTd>
            <MudTd>
                <div class="d-flex align-center" style="gap:6px">
                    <MudTooltip Text="@SourceTypeDisplay.Label(TypeOf(context.SourceId))">
                        <MudIcon Icon="@SourceTypeDisplay.Icon(TypeOf(context.SourceId))" Size="Size.Small" />
                    </MudTooltip>
                    @(SourceNameOf(context.SourceId))
                </div>
            </MudTd>
            <MudTd>@(ScoreOf(context)?.ToString("N0") ?? "—")</MudTd>
            <MudTd>@((context.PublishedAt ?? context.FetchedAt).ToLocalTime().ToString("g"))</MudTd>
            <MudTd>@context.Status</MudTd>
            <MudTd>
                @if (context.Status == ContentItemStatus.Selected)
                {
                    <MudButton Size="Size.Small" Color="Color.Warning" OnClick="@(() => Mark(context, ContentItemStatus.New))">Unselect</MudButton>
                }
                else
                {
                    <MudButton Size="Size.Small" OnClick="@(() => Mark(context, ContentItemStatus.Selected))">Select</MudButton>
                }
                @if (context.Status == ContentItemStatus.Ignored)
                {
                    <MudButton Size="Size.Small" OnClick="@(() => Mark(context, ContentItemStatus.New))">Restore</MudButton>
                }
                else
                {
                    <MudButton Size="Size.Small" OnClick="@(() => Mark(context, ContentItemStatus.Ignored))">Ignore</MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ContentItem> _items = [];
    private List<Recipe> _recipes = [];
    private HashSet<ContentItem> _selectedItems = [];
    private Guid? _recipeId;
    private List<ContentItem> _all = [];
    private Dictionary<Guid, Source> _sourcesById = [];
    private string _statusFilter = "all";
    private string _typeFilter = "all";
    private string _sortMode = "date";
    private string _search = "";
    private DateTime? _from, _to;
    private string _extraInstructions = "";
    private bool _running;

    protected override async Task OnInitializedAsync()
    {
        Ctx.Changed += OnTenantChanged;
        await ReloadAllAsync();
    }

    private void OnTenantChanged() => _ = InvokeAsync(async () =>
    {
        try
        {
            _recipeId = null;
            _extraInstructions = "";
            await ReloadAllAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load tenant data: {ex.Message}", Severity.Error);
        }
    });

    private async Task ReloadAllAsync()
    {
        _recipes = Ctx.Initialized && Ctx.Active is not null ? await RecipeSvc.ListAsync(Ctx.Active.Id) : [];
        _sourcesById = Ctx.Initialized && Ctx.Active is not null
            ? (await SourceSvc.ListAsync(Ctx.Active.Id)).ToDictionary(s => s.Id)
            : [];
        await Reload();
    }

    private async Task OnFilterChanged(string filter)
    {
        _statusFilter = filter;
        await Reload();
    }

    private void OnTypeFilterChanged(string type)
    {
        _typeFilter = type;
        ApplyFilters();
    }

    private void OnSortChanged(string mode)
    {
        _sortMode = mode;
        ApplyFilters();
    }

    private async Task Reload()
    {
        if (!Ctx.Initialized || Ctx.Active is null) { _all = []; _items = []; _selectedItems = []; return; }
        ContentItemStatus? status = _statusFilter == "all" ? null : Enum.Parse<ContentItemStatus>(_statusFilter);
        _all = await ContentSvc.ListAsync(Ctx.Active.Id, status);
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _selectedItems = [];
        IEnumerable<ContentItem> query = _all;
        if (_typeFilter != "all")
            query = query.Where(i => _sourcesById.GetValueOrDefault(i.SourceId)?.Type == _typeFilter);
        if (_from is DateTime from)
            query = query.Where(i => (i.PublishedAt ?? i.FetchedAt).ToLocalTime().Date >= from.Date);
        if (_to is DateTime to)
            query = query.Where(i => (i.PublishedAt ?? i.FetchedAt).ToLocalTime().Date <= to.Date);
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(i =>
                i.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                i.Body.Contains(_search, StringComparison.OrdinalIgnoreCase));

        _items = _sortMode switch
        {
            // per source in listing order (rank from fetch metadata); unranked last
            "rank" => query.OrderBy(SourceNameOf0).ThenBy(RankOf).ToList(),
            "score" => query.OrderByDescending(i => ScoreOf(i) ?? -1).ToList(),
            _ => query.ToList()   // _all is already newest-first from the service
        };
    }

    private string SourceNameOf(Guid sourceId) => _sourcesById.GetValueOrDefault(sourceId)?.DisplayName ?? "?";
    private string SourceNameOf0(ContentItem item) => SourceNameOf(item.SourceId);
    private string TypeOf(Guid sourceId) => _sourcesById.GetValueOrDefault(sourceId)?.Type ?? "";

    private static int RankOf(ContentItem item)
    {
        try
        {
            using var doc = JsonDocument.Parse(item.MetadataJson);
            return doc.RootElement.TryGetProperty("rank", out var r) ? r.GetInt32() : int.MaxValue;
        }
        catch (JsonException)
        {
            return int.MaxValue;
        }
    }

    private static int? ScoreOf(ContentItem item)
    {
        try
        {
            using var doc = JsonDocument.Parse(item.MetadataJson);
            return doc.RootElement.TryGetProperty("score", out var s) ? s.GetInt32() : null;
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private async Task Mark(ContentItem item, ContentItemStatus status)
    {
        await ContentSvc.MarkAsync(item.Id, status);
        await Reload();
    }

    private async Task DeleteSelected()
    {
        var (deleted, keptUsed) = await ContentSvc.DeleteAsync(_selectedItems.Select(i => i.Id).ToList());
        Snackbar.Add(keptUsed > 0
            ? $"Deleted {deleted} item(s); kept {keptUsed} already used in an issue"
            : $"Deleted {deleted} item(s)", Severity.Success);
        await Reload();
    }

    private async Task RunWithSelection()
    {
        _running = true;
        Snackbar.Add("Generating draft from selected items...", Severity.Info);
        try
        {
            var ids = _selectedItems.Select(i => i.Id).ToList();
            using var scope = ScopeFactory.CreateScope();
            var generation = scope.ServiceProvider.GetRequiredService<GenerationPipeline>();
            var (run, draft) = await generation.RunAsync(_recipeId!.Value, ids,
                string.IsNullOrWhiteSpace(_extraInstructions) ? null : _extraInstructions);
            if (run.Status == RunStatus.Succeeded)
                Snackbar.Add($"Draft delivered: {draft!.FilePath}", Severity.Success);
            else
                Snackbar.Add($"Run {run.Status}: {run.LogJson}", Severity.Error);
        }
        finally
        {
            _running = false;
            await Reload();
        }
    }

    public void Dispose() => Ctx.Changed -= OnTenantChanged;
}
