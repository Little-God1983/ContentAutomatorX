@page "/ai-studio"
@using ContentAutomatorX.Domain.Abstractions
@using ContentAutomatorX.Domain.Models
@using ContentAutomatorX.Web.Services
@implements IDisposable
@inject TenantContext Ctx
@inject ILlmSettingsProvider Settings
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">AI Studio</MudText>

@if (!Ctx.Initialized)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (Ctx.Active is null)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Create a tenant first — model settings are per tenant.</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mb-6" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-1">Model — @Ctx.Active.Name</MudText>
        <MudText Typo="Typo.caption" Class="mb-4 d-block">
            Applies to every ✨ action for this tenant: topic blurbs, subject ideas,
            regenerate, and LLM research sources. Other tenants keep their own settings.
        </MudText>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField T="string" Value="@("Claude CLI")" Label="Provider" ReadOnly="true" Disabled="true"
                              Variant="Variant.Outlined" HelperText="Only provider today" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_model" Label="Model" Variant="Variant.Outlined"
                           HelperText="@_modelInherited">
                    <MudSelectItem T="string" Value="@("")">Default (CLI decides)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("opus")">Opus</MudSelectItem>
                    <MudSelectItem T="string" Value="@("sonnet")">Sonnet</MudSelectItem>
                    <MudSelectItem T="string" Value="@("haiku")">Haiku</MudSelectItem>
                    <MudSelectItem T="string" Value="@("fable")">Fable</MudSelectItem>
                    <MudSelectItem T="string" Value="@CustomOption">Custom…</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="LlmEffort" @bind-Value="_effort" Label="Effort" Variant="Variant.Outlined"
                           HelperText="@_effortInherited">
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Default">Default (CLI decides)</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Low">low</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Medium">medium</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.High">high</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.XHigh">xhigh</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Max">max</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (_model == CustomOption)
            {
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_custom" Label="Custom model ID" Variant="Variant.Outlined"
                                  Placeholder="claude-opus-4-8" Error="@(_error is not null)"
                                  ErrorText="@_error" Immediate="true" />
                </MudItem>
            }
        </MudGrid>

        <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_saving" OnClick="SaveAsync">Save</MudButton>
    </MudPaper>
}

<ComingSoonBanner Phase="provider profiles land with the newsletter vertical; the full job-binding table grows with each phase"
                  Description="Provider profiles (Claude CLI, LM Studio, Ollama, hosted APIs, MCP servers, TTS — local solutions are first-class) get bound to named jobs like newsletter-compose or yt-description. Every ✨ button in the app runs a job; swapping the model behind it is editing one row here. Manual always works — AI only ever proposes text into ordinary fields." />

<MudGrid Style="opacity:.8">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Provider profiles (planned)</MudText>
            <MudSimpleTable Dense="true">
                <thead>
                    <tr><th style="text-align:left">Name</th><th style="text-align:left">Kind</th></tr>
                </thead>
                <tbody>
                    <tr><td>Claude CLI</td><td>text · CLI (exists today as the built-in backend)</td></tr>
                    <tr><td>LM Studio</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Ollama</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Hosted APIs / MCP</td><td>text · vendor API or MCP proxy</td></tr>
                    <tr><td>TTS (e.g. ElevenLabs)</td><td>voice · for optional AI voiceovers</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Job bindings (planned)</MudText>
            <MudSimpleTable Dense="true">
                <thead>
                    <tr><th style="text-align:left">Job</th><th style="text-align:left">Default provider</th></tr>
                </thead>
                <tbody>
                    <tr><td>newsletter-compose</td><td>Claude CLI</td></tr>
                    <tr><td>yt-title / yt-description</td><td>—</td></tr>
                    <tr><td>image-post-descr</td><td>—</td></tr>
                    <tr><td>patreon-teaser</td><td>—</td></tr>
                    <tr><td>voiceover-tts</td><td>—</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.caption" Class="mt-2 d-block">
    Today the card above is the whole resolution order: this tenant's stored choice,
    else the appsettings default, else whatever the CLI picks. Per-job and per-run
    choices are not built yet — see docs/mockups/10-platforms-ai-settings.md.
</MudText>

@code {
    // Sentinel for the "Custom…" dropdown entry. Contains a space, so
    // LlmModelName.IsValid rejects it — it can never be saved as a real model.
    private const string CustomOption = "custom model";

    private string _model = "";
    private string _custom = "";
    private LlmEffort _effort = LlmEffort.Default;
    private string? _modelInherited;
    private string? _effortInherited;
    private string? _error;
    private bool _saving;

    // MainLayout owns Ctx.InitializeAsync (it needs JS interop, so it runs after first
    // render) and raises Changed when it completes. Calling it here too would load the
    // card twice on every open, with both loads racing on the same scoped AppDbContext.
    protected override async Task OnInitializedAsync()
    {
        Ctx.Changed += OnTenantChanged;
        await LoadAsync();
    }

    private void OnTenantChanged() => _ = InvokeAsync(async () =>
    {
        try
        {
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Ctx.Active has already moved to the new tenant. Leaving the previous
            // tenant's model, effort and name on screen would let the next Save write
            // tenant A's choice onto tenant B — silently, and across tenants. Blank the
            // card instead, so what is on screen is never another tenant's data.
            ClearCard();
            StateHasChanged();
            Snackbar.Add($"Failed to load model settings: {ex.Message}", Severity.Error);
        }
    });

    private async Task LoadAsync()
    {
        if (!Ctx.Initialized || Ctx.Active is null)
        {
            ClearCard();
            return;
        }

        // The dropdowns bind to what this tenant stored, not to the resolved value:
        // binding the resolved value would make Save promote an inherited default into
        // an explicit row, and would make "Default (CLI decides)" unselectable whenever
        // appsettings names a model. The resolved value is read only to report what an
        // unset field currently inherits.
        var stored = await Settings.GetStoredAsync(Ctx.Active.Id);
        var resolved = await Settings.GetAsync(Ctx.Active.Id);

        _effort = stored.Effort;
        _error = null;
        if (stored.Model is "" or "opus" or "sonnet" or "haiku" or "fable")
        {
            _model = stored.Model;
            _custom = "";
        }
        else
        {
            _model = CustomOption;
            _custom = stored.Model;
        }

        _modelInherited = stored.Model.Length == 0 && resolved.Model.Length > 0
            ? $"unset — inheriting {resolved.Model} from appsettings"
            : null;
        _effortInherited = stored.Effort == LlmEffort.Default && resolved.Effort != LlmEffort.Default
            ? $"unset — inheriting {LlmSettings.ToStorage(resolved.Effort)} from appsettings"
            : null;
    }

    private void ClearCard()
    {
        _model = "";
        _custom = "";
        _effort = LlmEffort.Default;
        _modelInherited = null;
        _effortInherited = null;
        _error = null;
    }

    private async Task SaveAsync()
    {
        if (Ctx.Active is null) return;
        if (_saving) return;
        var model = _model == CustomOption ? _custom.Trim() : _model;

        // Mirror of the service's rule so the error lands on the field. The service
        // validates again on its own — this is convenience, not the enforcement point.
        if (model.Length > 0 && !LlmModelName.IsValid(model))
        {
            _error = $"Letters, digits, dot, underscore, hyphen or square brackets only, "
                   + $"up to {LlmModelName.MaxLength} characters.";
            return;
        }

        _error = null;
        _saving = true;
        try
        {
            await Settings.SaveAsync(Ctx.Active.Id, new LlmSettings(model, _effort));
            // Re-read so the card shows what was actually stored: a saved-blank field
            // becomes "Default", and picks up its inherited-from-appsettings note now
            // rather than surprising the user on the next visit.
            await LoadAsync();
            Snackbar.Add($"Model settings saved for {Ctx.Active.Name}.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose() => Ctx.Changed -= OnTenantChanged;
}
