                <thead>
                    <tr><th style="text-align:left">Name</th><th style="text-align:left">Kind</th></tr>
                </thead>
                <tbody>
                    <tr><td>Claude CLI</td><td>text · CLI (exists today as the built-in backend)</td></tr>
                    <tr><td>LM Studio</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Ollama</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Hosted APIs / MCP</td><td>text · vendor API or MCP proxy</td></tr>
                    <tr><td>TTS (e.g. ElevenLabs)</td><td>voice · for optional AI voiceovers</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Outlined="true">
