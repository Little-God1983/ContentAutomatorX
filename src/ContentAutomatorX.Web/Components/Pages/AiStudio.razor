@page "/ai-studio"
@using ContentAutomatorX.Domain.Abstractions
@using ContentAutomatorX.Domain.Models
@using ContentAutomatorX.Web.Services
@implements IDisposable
@inject TenantContext Ctx
@inject ILlmSettingsProvider Settings
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">AI Studio</MudText>

@if (!Ctx.Initialized)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (Ctx.Active is null)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Create a tenant first — model settings are per tenant.</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mb-6" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-1">Model — @Ctx.Active.Name</MudText>
        <MudText Typo="Typo.caption" Class="mb-4 d-block">
            Applies to every ✨ action for this tenant: topic blurbs, subject ideas,
            regenerate, and LLM research sources. Other tenants keep their own settings.
        </MudText>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField T="string" Value="@("Claude CLI")" Label="Provider" ReadOnly="true" Disabled="true"
                              Variant="Variant.Outlined" HelperText="Only provider today" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_model" Label="Model" Variant="Variant.Outlined"
                           HelperText="@_modelInherited">
                    <MudSelectItem T="string" Value="@("")">Default (CLI decides)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("opus")">Opus</MudSelectItem>
                    <MudSelectItem T="string" Value="@("sonnet")">Sonnet</MudSelectItem>
                    <MudSelectItem T="string" Value="@("haiku")">Haiku</MudSelectItem>
                    <MudSelectItem T="string" Value="@("fable")">Fable</MudSelectItem>
                    <MudSelectItem T="string" Value="@CustomOption">Custom…</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="LlmEffort" @bind-Value="_effort" Label="Effort" Variant="Variant.Outlined"
                           HelperText="@_effortInherited">
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Default">Default (CLI decides)</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Low">low</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Medium">medium</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.High">high</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.XHigh">xhigh</MudSelectItem>
                    <MudSelectItem T="LlmEffort" Value="LlmEffort.Max">max</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (_model == CustomOption)
            {
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_custom" Label="Custom model ID" Variant="Variant.Outlined"
                                  Placeholder="claude-opus-4-8" Error="@(_error is not null)"
                                  ErrorText="@_error" Immediate="true" />
                </MudItem>
            }
        </MudGrid>

        <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_saving || _loadFailed)" OnClick="SaveAsync">Save</MudButton>

        @if (_loadFailed)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">Settings could not be loaded. Try switching tenants again.</MudAlert>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mb-6" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-1">Per-job overrides — @Ctx.Active.Name</MudText>
        <MudText Typo="Typo.caption" Class="mb-4 d-block">
            Each ✨ action can pin its own model and effort. A row left on <em>Inherit</em> uses the
            tenant default above (then the appsettings default, then whatever the CLI picks). Cheap
            jobs like subject ideas can stay on a small model while research and drafting use a
            stronger one — instead of paying the strong model's rate for everything.
        </MudText>

        <MudSimpleTable Dense="true" Hover="true" Class="mb-3">
            <thead>
                <tr>
                    <th style="text-align:left">Job</th>
                    <th style="text-align:left">Model</th>
                    <th style="text-align:left">Effort</th>
                    <th style="text-align:left">Effective (saved)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _jobRows)
                {
                    <tr>
                        <td style="vertical-align:top">
                            <MudText Typo="Typo.body2" Class="mt-3">@JobLabel(row.Job)</MudText>
                            @if (row.Model == CustomOption)
                            {
                                <MudTextField @bind-Value="row.Custom" Label="Custom model ID" Margin="Margin.Dense"
                                              Variant="Variant.Outlined" Placeholder="claude-opus-4-8" Class="mt-1" />
                            }
                        </td>
                        <td style="vertical-align:top; min-width:150px">
                            <MudSelect T="string" @bind-Value="row.Model" Margin="Margin.Dense"
                                       Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem T="string" Value="@("")">Inherit</MudSelectItem>
                                <MudSelectItem T="string" Value="@("opus")">Opus</MudSelectItem>
                                <MudSelectItem T="string" Value="@("sonnet")">Sonnet</MudSelectItem>
                                <MudSelectItem T="string" Value="@("haiku")">Haiku</MudSelectItem>
                                <MudSelectItem T="string" Value="@("fable")">Fable</MudSelectItem>
                                <MudSelectItem T="string" Value="@CustomOption">Custom…</MudSelectItem>
                            </MudSelect>
                        </td>
                        <td style="vertical-align:top; min-width:130px">
                            <MudSelect T="LlmEffort" @bind-Value="row.Effort" Margin="Margin.Dense"
                                       Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.Default">Inherit</MudSelectItem>
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.Low">low</MudSelectItem>
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.Medium">medium</MudSelectItem>
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.High">high</MudSelectItem>
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.XHigh">xhigh</MudSelectItem>
                                <MudSelectItem T="LlmEffort" Value="LlmEffort.Max">max</MudSelectItem>
                            </MudSelect>
                        </td>
                        <td style="vertical-align:top"><MudText Typo="Typo.caption" Class="mt-3 d-block">@row.Effective</MudText></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (_jobError is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_jobError</MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_savingJobs || _loadFailed)" OnClick="SaveJobsAsync">Save job overrides</MudButton>
    </MudPaper>
}

<ComingSoonBanner Phase="model + effort are per-job today; multi-provider profiles land with the newsletter vertical"
                  Description="The next step is provider profiles (Claude CLI, LM Studio, Ollama, hosted APIs, MCP servers, TTS — local solutions are first-class) bound to each job, so a job can run on a different backend, not just a different Claude model. Every ✨ button in the app runs a job; swapping the model behind it is already editing one row above. Manual always works — AI only ever proposes text into ordinary fields." />

<MudGrid Style="opacity:.8">
    <MudItem xs="12">
        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Provider profiles (planned)</MudText>
            <MudSimpleTable Dense="true">
                <thead>
                    <tr><th style="text-align:left">Name</th><th style="text-align:left">Kind</th></tr>
                </thead>
                <tbody>
                    <tr><td>Claude CLI</td><td>text · CLI (exists today as the built-in backend)</td></tr>
                    <tr><td>LM Studio</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Ollama</td><td>text · OpenAI-compatible local HTTP</td></tr>
                    <tr><td>Hosted APIs / MCP</td><td>text · vendor API or MCP proxy</td></tr>
                    <tr><td>TTS (e.g. ElevenLabs)</td><td>voice · for optional AI voiceovers</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.caption" Class="mt-2 d-block">
    Resolution order: the job's own override, else this tenant's default, else the appsettings
    default, else whatever the CLI picks — each of model and effort resolved independently. What is
    not built yet is binding a job to a different <em>provider</em> (LM Studio, Ollama, hosted APIs)
    and per-run choices — see docs/mockups/10-platforms-ai-settings.md.
</MudText>

@code {
    // Sentinel for the "Custom…" dropdown entry. Contains a space, so
    // LlmModelName.IsValid rejects it — it can never be saved as a real model.
    private const string CustomOption = "custom model";

    private string _model = "";
    private string _custom = "";
    private LlmEffort _effort = LlmEffort.Default;
    private string? _modelInherited;
    private string? _effortInherited;
    private string? _error;
    private bool _saving;
    private bool _loadFailed;
    private readonly TenantReloadGate _reloadGate = new(); // #16: serialise tenant reloads (latest-wins)

    // Per-job overrides (#17): one editable row per LlmJobs key. Bound to GetStoredAsync per job
    // (Inherit when the tenant has no override for it) with the same stored-vs-resolved discipline
    // as the default card, so Save never promotes an inherited value into an explicit row.
    private List<JobRow> _jobRows = [];
    private string? _jobError;
    private bool _savingJobs;

    private sealed class JobRow
    {
        public string Job = "";
        public string Model = "";           // "" = inherit; an alias; or CustomOption
        public string Custom = "";
        public LlmEffort Effort = LlmEffort.Default;
        public string? Effective;           // what this job resolves to as saved, for the last column
    }

    // MainLayout owns Ctx.InitializeAsync (it needs JS interop, so it runs after first
    // render) and raises Changed when it completes. Calling it here too would load the
    // card twice on every open, with both loads racing on the same scoped AppDbContext.
    // The gate serialises those loads so they can no longer overlap that context.
    protected override async Task OnInitializedAsync()
    {
        Ctx.Changed += OnTenantChanged;
        await _reloadGate.RunAsync(LoadAsync);
    }

    private void OnTenantChanged() => _ = InvokeAsync(() => _reloadGate.RunAsync(async () =>
    {
        try
        {
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Ctx.Active has already moved to the new tenant. Leaving the previous
            // tenant's model, effort and name on screen would let the next Save write
            // tenant A's choice onto tenant B — silently, and across tenants. Blank the
            // card instead, so what is on screen is never another tenant's data.
            ClearCard();
            _loadFailed = true;
            StateHasChanged();
            Snackbar.Add($"Failed to load model settings: {ex.Message}", Severity.Error);
        }
    }));

    private async Task LoadAsync()
    {
        _loadFailed = false;
        if (!Ctx.Initialized || Ctx.Active is null)
        {
            ClearCard();
            return;
        }

        // The dropdowns bind to what this tenant stored, not to the resolved value:
        // binding the resolved value would make Save promote an inherited default into
        // an explicit row, and would make "Default (CLI decides)" unselectable whenever
        // appsettings names a model. The resolved value is read only to report what an
        // unset field currently inherits.
        var stored = await Settings.GetStoredAsync(Ctx.Active.Id);
        var resolved = await Settings.GetAsync(Ctx.Active.Id);

        _effort = stored.Effort;
        _error = null;
        if (stored.Model is "" or "opus" or "sonnet" or "haiku" or "fable")
        {
            _model = stored.Model;
            _custom = "";
        }
        else
        {
            _model = CustomOption;
            _custom = stored.Model;
        }

        _modelInherited = stored.Model.Length == 0 && resolved.Model.Length > 0
            ? $"unset — inheriting {resolved.Model} from appsettings"
            : null;
        _effortInherited = stored.Effort == LlmEffort.Default && resolved.Effort != LlmEffort.Default
            ? $"unset — inheriting {LlmSettings.ToStorage(resolved.Effort)} from appsettings"
            : null;

        // Per-job rows: what the tenant stored for each job (GetStored, so "inherit" stays "inherit")
        // and what each job currently resolves to (Get, for the "Effective" column).
        var jobRows = new List<JobRow>();
        foreach (var job in LlmJobs.All)
        {
            var jobStored = await Settings.GetStoredAsync(Ctx.Active.Id, job);
            var jobResolved = await Settings.GetAsync(Ctx.Active.Id, job);
            var r = new JobRow { Job = job, Effort = jobStored.Effort, Effective = DescribeEffective(jobResolved) };
            if (jobStored.Model is "" or "opus" or "sonnet" or "haiku" or "fable")
                (r.Model, r.Custom) = (jobStored.Model, "");
            else
                (r.Model, r.Custom) = (CustomOption, jobStored.Model);
            jobRows.Add(r);
        }
        _jobRows = jobRows;
        _jobError = null;
    }

    private void ClearCard()
    {
        _model = "";
        _custom = "";
        _effort = LlmEffort.Default;
        _modelInherited = null;
        _effortInherited = null;
        _error = null;
        _jobRows = [];
        _jobError = null;
    }

    private static string JobLabel(string job) => job switch
    {
        LlmJobs.TopicBlurbs => "Topic blurbs",
        LlmJobs.RegenerateSection => "Regenerate section",
        LlmJobs.ComposerChat => "Composer chat",
        LlmJobs.SubjectIdeas => "Subject ideas",
        LlmJobs.RecipeDraft => "Recipe draft",
        LlmJobs.Research => "Research",
        _ => job
    };

    private static string DescribeEffective(LlmSettings resolved) =>
        $"{(resolved.Model.Length == 0 ? "CLI default" : resolved.Model)} · " +
        $"{(resolved.Effort == LlmEffort.Default ? "CLI default" : LlmSettings.ToStorage(resolved.Effort))}";

    private async Task SaveJobsAsync()
    {
        if (Ctx.Active is null || _savingJobs) return;

        // Validate every custom model up front so the whole save is atomic-ish: nothing is written
        // if any row is invalid. Mirror of the service's rule so the error lands on this card.
        foreach (var row in _jobRows)
        {
            var model = row.Model == CustomOption ? row.Custom.Trim() : row.Model;
            if (model.Length > 0 && !LlmModelName.IsValid(model))
            {
                _jobError = $"{JobLabel(row.Job)}: '{model}' is not a valid model name. "
                          + $"Letters, digits, dot, underscore, hyphen or square brackets, up to {LlmModelName.MaxLength} characters.";
                return;
            }
        }

        _jobError = null;
        _savingJobs = true;
        // Capture the tenant once: the loop awaits per row, and a tenant switch landing between two
        // of those awaits would otherwise make the remaining rows write this tenant's values onto the
        // newly-active one — the same cross-tenant hazard the default card's SaveAsync avoids.
        var tenant = Ctx.Active;
        try
        {
            foreach (var row in _jobRows)
            {
                var model = row.Model == CustomOption ? row.Custom.Trim() : row.Model;
                await Settings.SaveAsync(tenant.Id, new LlmSettings(model, row.Effort), row.Job);
            }
            Snackbar.Add($"Job overrides saved for {tenant.Name}.", Severity.Success);
        }
        catch (ArgumentException ex) { _jobError = ex.Message; }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _savingJobs = false; }

        // Re-read so the card reflects what was stored: fully-inherited rows drop back to "Inherit"
        // and the Effective column refreshes. Its own try so a reload failure is not a save failure.
        try { await LoadAsync(); } catch { }
    }

    private async Task SaveAsync()
    {
        if (Ctx.Active is null) return;
        if (_saving) return;
        var model = _model == CustomOption ? _custom.Trim() : _model;

        // Mirror of the service's rule so the error lands on the field. The service
        // validates again on its own — this is convenience, not the enforcement point.
        if (model.Length > 0 && !LlmModelName.IsValid(model))
        {
            _error = $"Letters, digits, dot, underscore, hyphen or square brackets only, "
                   + $"up to {LlmModelName.MaxLength} characters.";
            return;
        }

        _error = null;
        _saving = true;
        try
        {
            await Settings.SaveAsync(Ctx.Active.Id, new LlmSettings(model, _effort));
            Snackbar.Add($"Model settings saved for {Ctx.Active.Name}.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }

        // Re-read so the card shows what was actually stored: a saved-blank field
        // becomes "Default", and picks up its inherited-from-appsettings note now
        // rather than surprising the user on the next visit. Wrapped in its own try
        // so a reload failure is not reported as a save failure.
        try
        {
            await LoadAsync();
        }
        catch
        {
            // Reload failed, but save succeeded. Continue silently.
        }
    }

    public void Dispose()
    {
        Ctx.Changed -= OnTenantChanged;
        _reloadGate.Dispose();
    }
}
