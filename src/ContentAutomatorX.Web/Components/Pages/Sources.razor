@page "/sources"
@implements IDisposable
@using ContentAutomatorX.Domain.Abstractions
@using ContentAutomatorX.Infrastructure.Sources
@inject TenantContext Ctx
@inject SourceService SourceSvc
@inject ICredentialStore Credentials
@inject RedditConnector RedditConn
@inject IServiceScopeFactory ScopeFactory
@inject ISnackbar Snackbar
@inject IScrollManager ScrollManager

<MudText Typo="Typo.h4" Class="mb-4">Sources</MudText>

@if (!Ctx.Initialized)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (Ctx.Active is null)
{
    <NoTenantHint />
}
else
{
    <MudPaper Class="pa-4 mb-4" id="source-form">
        <MudText Typo="Typo.h6">@(_editing is null ? "New source" : $"Edit: {_editing.DisplayName}")</MudText>
        <MudSelect T="string" @bind-Value="_type" Label="Type">
            <MudSelectItem T="string" Value="@SourceTypes.Reddit">Reddit</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.Rss">RSS/Atom feed</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.Website">Website (page watch)</MudSelectItem>
            <MudSelectItem T="string" Value="@SourceTypes.LlmResearch">LLM research (AI web sweep)</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_displayName" Label="Display name" />
        @if (_type == SourceTypes.Reddit)
        {
            <MudTextField @bind-Value="_subreddit" Label="Subreddit (without r/)" />
            <MudSelect T="string" @bind-Value="_sort" Label="Sort">
                <MudSelectItem T="string" Value="@("hot")">Hot</MudSelectItem>
                <MudSelectItem T="string" Value="@("new")">New</MudSelectItem>
                <MudSelectItem T="string" Value="@("top")">Top</MudSelectItem>
                <MudSelectItem T="string" Value="@("rising")">Rising</MudSelectItem>
            </MudSelect>
            @if (_sort == "top")
            {
                <MudSelect T="string" @bind-Value="_timeframe" Label="Top of the last">
                    <MudSelectItem T="string" Value="@("hour")">Hour</MudSelectItem>
                    <MudSelectItem T="string" Value="@("day")">Day</MudSelectItem>
                    <MudSelectItem T="string" Value="@("week")">Week</MudSelectItem>
                    <MudSelectItem T="string" Value="@("month")">Month</MudSelectItem>
                    <MudSelectItem T="string" Value="@("year")">Year</MudSelectItem>
                    <MudSelectItem T="string" Value="@("all")">All time</MudSelectItem>
                </MudSelect>
            }
            <MudNumericField T="int" @bind-Value="_limit" Label="Items per fetch" Min="1" Max="20" />
        }
        else if (_type == SourceTypes.Website)
        {
            <MudTextField @bind-Value="_siteUrl" Label="Page URL (listing/blog index)" />
            <MudSelect T="string" @bind-Value="_siteMode" Label="Extraction">
                <MudSelectItem T="string" Value="@("auto")">Auto (articles & main links)</MudSelectItem>
                <MudSelectItem T="string" Value="@("selector")">CSS selector</MudSelectItem>
            </MudSelect>
            @if (_siteMode == "selector")
            {
                <MudTextField @bind-Value="_siteSelector" Label="Item selector (e.g. .post-list a)" />
            }
        }
        else if (_type == SourceTypes.LlmResearch)
        {
            <MudTextField @bind-Value="_researchPrompt" Label="Research prompt" Lines="3"
                          HelperText="E.g. 'top AI image-generation news of the past 7 days'. Runs via the LLM with web search (Claude ExtraArgs)." />
        }
        else
        {
            <MudTextField @bind-Value="_feedUrl" Label="Feed URL" />
        }
        <MudTextField @bind-Value="_cron" Label="Schedule (cron, UTC; e.g. '0 6 * * *' = daily 06:00; empty = manual only)" />
        <MudSwitch T="bool" @bind-Value="_enabled" Label="Enabled" Color="Color.Primary" />
        <div class="mt-2">
            <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary" Class="mr-2">Save</MudButton>
            @if (_editing is not null)
            {
                <MudButton OnClick="Reset">Cancel</MudButton>
            }
        </div>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.h6">Reddit API (optional)</MudText>
        <MudText Typo="Typo.body2" Class="mb-2" Style="opacity:.8">
            Without credentials, Reddit is fetched via its public feed — no upvote counts.
            Create a free <b>script</b> app at
            <MudLink Href="https://www.reddit.com/prefs/apps" Target="_blank">reddit.com/prefs/apps</MudLink>
            and paste its values here. Stored encrypted on this PC (DPAPI), applies to all tenants.
            @(_redditConfigured ? " Status: configured ✓" : " Status: not configured")
        </MudText>
        <MudTextField @bind-Value="_redditClientId" Label="Client id (under the app name, ~14 chars)" />
        <MudTextField @bind-Value="_redditSecret" Label="Client secret" InputType="InputType.Password" />
        <div class="mt-2">
            <MudButton OnClick="SaveRedditCreds" Variant="Variant.Filled" Color="Color.Primary" Class="mr-2"
                       Disabled="@(string.IsNullOrWhiteSpace(_redditClientId) || string.IsNullOrWhiteSpace(_redditSecret))">
                Save
            </MudButton>
            <MudButton OnClick="TestRedditCreds" Class="mr-2" Disabled="@(!_redditConfigured || _redditTesting)">Test</MudButton>
            <MudButton OnClick="RemoveRedditCreds" Color="Color.Error" Disabled="@(!_redditConfigured)">Remove</MudButton>
        </div>
    </MudPaper>

    <MudTable Items="_sources" Hover="true">
        <HeaderContent>
            <MudTh>Name</MudTh><MudTh>Type</MudTh><MudTh>Schedule</MudTh><MudTh>Enabled</MudTh><MudTh>Last fetched</MudTh><MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.DisplayName</MudTd>
            <MudTd>@context.Type</MudTd>
            <MudTd>@(context.ScheduleCron ?? "manual")</MudTd>
            <MudTd>@(context.IsEnabled ? "yes" : "no")</MudTd>
            <MudTd>@(context.LastFetchedAt?.ToLocalTime().ToString("g") ?? "never")</MudTd>
            <MudTd>
                <MudButton Size="Size.Small" OnClick="@(() => FetchNow(context))">Fetch now</MudButton>
                <MudButton Size="Size.Small" OnClick="@(() => Edit(context))">Edit</MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context))">Delete</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Source> _sources = [];
    private Source? _editing;
    private string _type = SourceTypes.Reddit, _displayName = "", _subreddit = "", _sort = "hot",
        _timeframe = "week", _feedUrl = "", _cron = "";
    private int _limit = 20;
    private string _siteUrl = "", _siteMode = "auto", _siteSelector = "", _researchPrompt = "";
    private bool _enabled = true;
    private string _redditClientId = "", _redditSecret = "";
    private bool _redditConfigured, _redditTesting;

    protected override async Task OnInitializedAsync()
    {
        Ctx.Changed += OnTenantChanged;
        _redditConfigured = !string.IsNullOrEmpty(await Credentials.GetAsync(RedditConnector.CredentialName));
        await ReloadAsync();
    }

    private void OnTenantChanged() => _ = InvokeAsync(async () =>
    {
        try
        {
            Reset();
            await ReloadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load tenant data: {ex.Message}", Severity.Error);
        }
    });

    private async Task ReloadAsync()
    {
        _sources = Ctx.Initialized && Ctx.Active is not null ? await SourceSvc.ListAsync(Ctx.Active.Id) : [];
    }

    private async Task Edit(Source s)
    {
        _editing = s;
        _type = s.Type; _displayName = s.DisplayName; _cron = s.ScheduleCron ?? ""; _enabled = s.IsEnabled;
        (_subreddit, _sort, _timeframe, _feedUrl, _siteUrl, _siteMode, _siteSelector, _researchPrompt)
            = ("", "hot", "week", "", "", "auto", "", "");
        _limit = 20;
        using var doc = JsonDocument.Parse(s.ConfigJson);
        if (s.Type == SourceTypes.Reddit)
        {
            _subreddit = doc.RootElement.TryGetProperty("subreddit", out var v) ? v.GetString() ?? "" : "";
            // normalize legacy free-text values ("Hot") so they match the dropdown options
            _sort = (doc.RootElement.TryGetProperty("sort", out var so) ? so.GetString() ?? "hot" : "hot").ToLowerInvariant();
            _timeframe = (doc.RootElement.TryGetProperty("timeframe", out var tf) ? tf.GetString() ?? "week" : "week").ToLowerInvariant();
            _limit = Math.Clamp(doc.RootElement.TryGetProperty("limit", out var li) && li.TryGetInt32(out var lim) ? lim : 20, 1, 20);
        }
        else if (s.Type == SourceTypes.Website)
        {
            _siteUrl = doc.RootElement.TryGetProperty("url", out var u) ? u.GetString() ?? "" : "";
            _siteMode = doc.RootElement.TryGetProperty("mode", out var m) ? m.GetString() ?? "auto" : "auto";
            _siteSelector = doc.RootElement.TryGetProperty("itemSelector", out var sel) ? sel.GetString() ?? "" : "";
        }
        else if (s.Type == SourceTypes.LlmResearch)
        {
            _researchPrompt = doc.RootElement.TryGetProperty("prompt", out var p) ? p.GetString() ?? "" : "";
        }
        else
        {
            _feedUrl = doc.RootElement.TryGetProperty("feedUrl", out var f) ? f.GetString() ?? "" : "";
        }
        // the form sits above the table — without this, Edit appears to do nothing
        await ScrollManager.ScrollToTopAsync("html", ScrollBehavior.Smooth);
    }

    private void Reset()
    {
        _editing = null;
        (_type, _displayName, _subreddit, _sort, _timeframe, _feedUrl, _cron, _enabled)
            = (SourceTypes.Reddit, "", "", "hot", "week", "", "", true);
        (_siteUrl, _siteMode, _siteSelector, _researchPrompt) = ("", "auto", "", "");
        _limit = 20;
    }

    private string BuildConfig() => _type switch
    {
        var t when t == SourceTypes.Reddit =>
            JsonSerializer.Serialize(new { subreddit = _subreddit, sort = _sort, timeframe = _timeframe, limit = _limit }),
        var t when t == SourceTypes.Website =>
            JsonSerializer.Serialize(new { url = _siteUrl, mode = _siteMode,
                itemSelector = _siteMode == "selector" ? _siteSelector : null }),
        var t when t == SourceTypes.LlmResearch =>
            JsonSerializer.Serialize(new { prompt = _researchPrompt }),
        _ => JsonSerializer.Serialize(new { feedUrl = _feedUrl })
    };

    private async Task Save()
    {
        if (Ctx.Active is null || string.IsNullOrWhiteSpace(_displayName)) return;
        if (_editing is null)
        {
            await SourceSvc.CreateAsync(new Source
            {
                TenantId = Ctx.Active.Id, Type = _type, DisplayName = _displayName,
                ConfigJson = BuildConfig(), ScheduleCron = string.IsNullOrWhiteSpace(_cron) ? null : _cron,
                IsEnabled = _enabled
            });
        }
        else
        {
            _editing.Type = _type; _editing.DisplayName = _displayName; _editing.ConfigJson = BuildConfig();
            _editing.ScheduleCron = string.IsNullOrWhiteSpace(_cron) ? null : _cron; _editing.IsEnabled = _enabled;
            await SourceSvc.UpdateAsync();
        }
        Reset();
        await ReloadAsync();
        Snackbar.Add("Saved", Severity.Success);
    }

    private async Task Delete(Source s)
    {
        try
        {
            var removedItems = await SourceSvc.DeleteAsync(s.Id);
            Snackbar.Add(removedItems > 0
                ? $"Deleted '{s.DisplayName}' and {removedItems} inbox item(s)"
                : $"Deleted '{s.DisplayName}'", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        await ReloadAsync();
    }

    private async Task SaveRedditCreds()
    {
        await Credentials.SetAsync(RedditConnector.CredentialName,
            JsonSerializer.Serialize(new { clientId = _redditClientId.Trim(), clientSecret = _redditSecret.Trim() }));
        (_redditClientId, _redditSecret, _redditConfigured) = ("", "", true);
        Snackbar.Add("Saved — Reddit fetches now use the official API. Hit Test to verify.", Severity.Success);
    }

    private async Task TestRedditCreds()
    {
        _redditTesting = true;
        try
        {
            await RedditConn.TestCredentialsAsync();
            Snackbar.Add("Reddit API OK — token issued.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _redditTesting = false; }
    }

    private async Task RemoveRedditCreds()
    {
        await Credentials.DeleteAsync(RedditConnector.CredentialName);
        _redditConfigured = false;
        Snackbar.Add("Removed — Reddit fetches fall back to the public feed.", Severity.Info);
    }

    private async Task FetchNow(Source s)
    {
        Snackbar.Add($"Fetching {s.DisplayName}...", Severity.Info);
        using var scope = ScopeFactory.CreateScope();
        var ingestion = scope.ServiceProvider.GetRequiredService<IngestionPipeline>();
        var run = await ingestion.RunAsync(s.TenantId, s.Id);
        Snackbar.Add($"Fetch {run.Status}: {run.LogJson}",
            run.Status == RunStatus.Succeeded ? Severity.Success : Severity.Error);
        await ReloadAsync();
    }

    public void Dispose() => Ctx.Changed -= OnTenantChanged;
}
