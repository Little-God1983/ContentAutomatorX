@inherits LayoutComponentBase
@inject TenantContext Ctx
@inject NavigationManager Nav

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!Ctx.Initialized || !Ctx.SelectionConfirmed)
{
    @* Entry gate: hold back the shell until a tenant is explicitly picked. On a
       fresh circuit OnAfterRenderAsync redirects to the picker, so this is only
       ever a brief placeholder — never a flash of the app chrome. *@
    <div class="app-gate">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else
{
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6">ContentAutomatorX</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleTheme"
                       title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")"
                       aria-label="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" />
        <NewMenu />
        <TenantSwitcher />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudNavMenu>
            <MudNavGroup Title="Plan" Expanded="true">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Today">Today</MudNavLink>
                <MudNavLink Href="/calendar" Icon="@Icons.Material.Filled.CalendarMonth">Calendar</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Work" Expanded="true">
                <MudNavLink Href="/inbox" Icon="@Icons.Material.Filled.Inbox">Inbox</MudNavLink>
                <MudNavLink Href="/projects" Icon="@Icons.Material.Filled.Folder">Projects</MudNavLink>
                <MudNavLink Href="/posts" Icon="@Icons.Material.Filled.Send">Posts</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Archive" Expanded="true">
                <MudNavLink Href="/library" Icon="@Icons.Material.Filled.LocalLibrary">Library</MudNavLink>
                <MudNavLink Href="/analytics" Icon="@Icons.Material.Filled.Insights">Analytics</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="System" Expanded="true">
                <MudNavLink Href="/sources" Icon="@Icons.Material.Filled.RssFeed">Sources</MudNavLink>
                <MudNavLink Href="/automations" Icon="@Icons.Material.Filled.Autorenew">Automations</MudNavLink>
                <MudNavLink Href="/platforms" Icon="@Icons.Material.Filled.Power">Platforms</MudNavLink>
                <MudNavLink Href="/ai-studio" Icon="@Icons.Material.Filled.SmartToy">AI Studio</MudNavLink>
                <MudNavLink Href="/runs" Icon="@Icons.Material.Filled.History">Runs</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pa-6">
        @Body
    </MudMainContent>
</MudLayout>
}

@code {
    private bool _drawerOpen = true;

    private MudThemeProvider _themeProvider = null!;
    // Dark on by default: the fallback if the OS preference can't be read.
    private bool _isDarkMode = true;
    // Once the user toggles manually, their choice wins over live OS changes (until reload).
    private bool _manualOverride;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // ProtectedLocalStorage and JS interop are unavailable before first render.
        if (!firstRender) return;

        await Ctx.InitializeAsync();

        if (!Ctx.SelectionConfirmed)
        {
            // No explicit pick yet this circuit — send them to the picker, carrying
            // the page they were trying to reach so we can return there afterwards.
            var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/select-tenant?returnUrl={Uri.EscapeDataString(returnUrl)}");
            return;
        }

        try
        {
            _isDarkMode = await _themeProvider.GetSystemDarkModeAsync();
            await _themeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChanged);
        }
        catch
        {
            // Couldn't read the OS preference — keep the dark default.
        }

        StateHasChanged();
    }

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        _manualOverride = true;
    }

    private Task OnSystemDarkModeChanged(bool isDark)
    {
        // Respect a manual choice; otherwise follow the OS live.
        if (_manualOverride) return Task.CompletedTask;

        return InvokeAsync(() =>
        {
            _isDarkMode = isDark;
            StateHasChanged();
        });
    }
}
